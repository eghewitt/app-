# 3. ENGINE IMPLEMENTATION (Recommendation & Filtering)
# ==========================================

class UpNextEngine:
    @staticmethod
    def get_dynamic_theme(dominant_mood: str) -> Dict[str, str]:
        themes = {
            "Adventure": {"bg": "#FF4500", "text": "#FFFFFF", "vibe": "Deep Orange & Red"},
            "Relaxing": {"bg": "#87CEEB", "text": "#111111", "vibe": "Soft Blue"},
            "Creative": {"bg": "#8A2BE2", "text": "#FFFFFF", "vibe": "Purple"},
            "Social": {"bg": "#FFD700", "text": "#111111", "vibe": "Warm Yellow"},
            "Nature": {"bg": "#228B22", "text": "#FFFFFF", "vibe": "Green"},
            "Romantic": {"bg": "#FF69B4", "text": "#FFFFFF", "vibe": "Pink & Sunset Tones"},
            "Productive": {"bg": "#4682B4", "text": "#FFFFFF", "vibe": "Clean Blue"},
            "Nightlife": {"bg": "#4B0082", "text": "#FFFFFF", "vibe": "Dark Purple"}
        }
        return themes.get(dominant_mood, {"bg": "#FFFFFF", "text": "#000000", "vibe": "Modern Light"})

    @staticmethod
    def generate_recommendations(user: UserProfile, questionnaire: Dict[str, Any], 
                                     lat: float, lng: float) -> Dict[str, Any]:
        if not user.can_generate_recommendation():
            return {"status": "error", "message": "Subscription restriction. Upgrade or buy a session."}
        
        user.consume_session()
        
        scored_places = []
        for place in MOCK_PLACES_DATABASE:
            # Hard Filters (Budget, Time, Environment)
            if place.budget > questionnaire.get("budget", float('inf')):
                continue
            if place.time_required > questionnaire.get("available_time", 999):
                continue
            if questionnaire.get("indoor_outdoor") == "Indoor" and place.is_outdoor:
                continue
            if questionnaire.get("indoor_outdoor") == "Outdoor" and not place.is_outdoor:
                continue
            
            # Calculate Distance Bounds
            distance = place.calculate_distance(lat, lng)
            if distance > questionnaire.get("max_distance", 50.0):
                continue
                
            # Scoring Matrix Engine
            score = 0.0
            if place.base_mood.lower() == questionnaire.get("mood", "").lower():
                score += 40.0
            
            # Tag Matching Calculation
            matched_tags = set(place.tags).intersection(set([t.lower() for t in questionnaire.get("interests", [])]))
            score += len(matched_tags) * 15.0
            
            # Energy alignment
            if questionnaire.get("energy_level") == "Very High" and "high energy" in place.tags:
                score += 20.0
            
            # Group check
            if questionnaire.get("group_size", 1) >= 5 and "group" in place.tags:
                score += 15.0

            # Quality metrics booster
            score += place.rating * 2.0

            scored_places.append((score, place, distance))
            
        # Sort sequentially by calculated relevance score descending
        scored_places.sort(key=lambda x: x[0], reverse=True)
        
        # Semantic Category Deduplication Filtering Loop
        final_recommendations = []
        seen_categories = set()
        
        for score, place, dist in scored_places:
            if place.category in seen_categories:
                continue # Skip repetitive matches (e.g., skips secondary coffee shop)
            
            seen_categories.add(place.category)
            
            # Construct JSON Response payload format matching specifications
            final_recommendations.append({
                "business_name": place.name,
                "category": place.category,
                "relevance_score": round(score, 1),
                "distance_km": round(dist, 2),
                "rating": place.rating,
                "reviews_count": place.reviews_count,
                "why_recommended": f"Matches your requested {place.base_mood} mood with an optimized score profile.",
                "actions": {
                    "get_me_there_url": f"https://www.google.com/maps/dir/?api=1&destination={place.lat},{place.lng}",
                    "save_for_later": True,
                    "schedule_activity": True
                }
            })
            
            if len(final_recommendations) == 10:
                break
                
        # Handle dynamic fallback logic to safely ensure 10 items if database allows
        dominant_mood = questionnaire.get("mood", "Social")
        
        return {
            "status": "success",
            "ui_theme": UpNextEngine.get_dynamic_theme(dominant_mood),
            "total_found": len(final_recommendations),
            "recommendations": final_recommendations
        }

    @staticmethod
    def quick_search(query: str, lat: float, lng: float) -> List[Dict[str, Any]]:
        results = []
        query_clean = query.lower()
        
        for place in MOCK_PLACES_DATABASE:
            # Direct exact match or categorical subset contains verification
            if query_clean in place.name.lower() or query_clean in place.category.lower() or any(query_clean in t for t in place.tags):
                dist = place.calculate_distance(lat, lng)
                results.append({
                    "business_name": place.name,
                    "category": place.category,
                    "distance_km": round(dist, 2),
                    "rating": place.rating,
                    "actions": {
                        "get_me_there_url": f"https://www.google.com/maps/dir/?api=1&destination={place.lat},{place.lng}"
                    }
                })
        return results


