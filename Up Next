class UserProfile:
    def __init__(self, user_id: str, subscription_status: str = "Free"):
        self.user_id = user_id
        self.subscription_status = subscription_status  # "Free", "Pro", "PayAsYouGo"
        self.free_sessions_remaining = 3
        self.favorites: List[Dict[str, Any]] = []
        self.history: List[Dict[str, Any]] = []
        self.calendar: List[Dict[str, Any]] = []

    def can_generate_recommendation(self) -> bool:
        if self.subscription_status == "Pro":
            return True
        if self.subscription_status == "Free" and self.free_sessions_remaining > 0:
            return True
        return False

    def consume_session(self):
        if self.subscription_status == "Free" and self.free_sessions_remaining > 0:
            self.free_sessions_remaining -= 1


class ActivityPlace:
    def __init__(self, name: str, category: str, tags: List[str], base_mood: str,
                 budget: float, time_required: int, is_outdoor: bool, 
                 rating: float, reviews_count: int, lat: float, lng: float):
        self.name = name
        self.category = category
        self.tags = [t.lower() for t in tags]
        self.base_mood = base_mood
        self.budget = budget
        self.time_required = time_required  # in minutes
        self.is_outdoor = is_outdoor
        self.rating = rating
        self.reviews_count = reviews_count
        self.lat = lat
        self.lng = lng

    def calculate_distance(self, user_lat: float, user_lng: float) -> float:
        # Simple Euclidean approximation for local distance modeling
        return ((self.lat - user_lat)**2 + (self.lng - user_lng)**2)**0.5 * 111.0


